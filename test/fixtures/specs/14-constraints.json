{
  "openapi": "3.1.0",
  "info": { "title": "Constraints Fixture", "version": "1.0.0" },
  "paths": {},
  "components": {
    "schemas": {
      "Widget": {
        "type": "object",
        "required": ["name", "score"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 3,
            "maxLength": 10,
            "pattern": "^[a-z]+$"
          },
          "score": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "multipleOf": 5
          },
          "ratio": {
            "type": "number",
            "exclusiveMinimum": 0,
            "exclusiveMaximum": 1
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "maxItems": 3,
            "uniqueItems": true
          },
          "note": { "type": "string" }
        }
      }
    }
  }
}
